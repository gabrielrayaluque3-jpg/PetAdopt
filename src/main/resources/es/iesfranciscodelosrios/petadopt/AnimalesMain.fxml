<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="650.0" prefWidth="1000.0" spacing="15.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="es.iesfranciscodelosrios.petadopt.controller.AnimalesMainController">
    <children>

        <MenuBar style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 0 0 1 0;">
            <menus>
                <Menu text="Menú">
                    <items>
                        <MenuItem onAction="#btnAnimales" text="Animales" />
                        <MenuItem onAction="#btnVoluntarios" text="Voluntarios" />
                        <MenuItem onAction="#btnTareas" text="Tareas" />
                        <MenuItem onAction="#btnAdoptantes" text="Adoptantes" />
                        <MenuItem onAction="#btnHistorial" text="Historial Tareas" />
                    </items>
                </Menu>
                <Menu text="Archivo">
                    <items>
                        <MenuItem onAction="#btnMenuPrincipal" text="Volver al Inicio" />
                        <SeparatorMenuItem />
                        <MenuItem onAction="#btnSalir" text="Cerrar Ventana" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>

        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 0 0 1 0;">
            <children>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Gestión de Animales" textFill="#212529">
                            <font>
                                <Font name="System Bold" size="22.0" />
                            </font>
                        </Label>
                        <Label text="Control de ingresos, edición de perfiles y asignación de voluntarios del refugio." textFill="#6c757d">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <TextField fx:id="txtBuscar" prefHeight="32.0" prefWidth="280.0" promptText="🔍 Buscar por nombre, raza..." style="-fx-background-radius: 4; -fx-border-color: #ced4da; -fx-border-radius: 4;" />
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
            </padding>
        </HBox>

        <TableView fx:id="tvAnimales" style="-fx-background-radius: 4; -fx-border-color: #dee2e6;" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colNombre" prefWidth="150.0" text="Nombre" />
                <TableColumn fx:id="colEspecie" prefWidth="120.0" text="Especie" />
                <TableColumn fx:id="colRaza" prefWidth="150.0" text="Raza" />
                <TableColumn fx:id="colEdad" prefWidth="80.0" text="Edad (Años)" />
                <TableColumn fx:id="colVoluntario" prefWidth="220.0" text="Voluntario Encargado" />
                <TableColumn fx:id="colAdoptante" prefWidth="220.0" text="Estado / Adoptante" />
            </columns>
            <VBox.margin>
                <Insets left="25.0" right="25.0" top="5.0" />
            </VBox.margin>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <Button onAction="#btnAddAnimal" prefHeight="38.0" prefWidth="160.0" style="-fx-background-color: #e8f5e9; -fx-border-color: #4caf50; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Añadir Animal" textFill="#2e7d32">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
                <Button onAction="#btnEditar" prefHeight="38.0" prefWidth="160.0" style="-fx-background-color: #e3f2fd; -fx-border-color: #2196f3; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Editar Animal" textFill="#0d47a1">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
                <Button onAction="#btnEliminar" prefHeight="38.0" prefWidth="160.0" style="-fx-background-color: #ffebee; -fx-border-color: #f44336; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Eliminar Animal" textFill="#c62828">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
            <VBox.margin>
                <Insets bottom="20.0" top="10.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>
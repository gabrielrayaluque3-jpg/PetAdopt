<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="650.0" prefWidth="850.0" spacing="0.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="es.iesfranciscodelosrios.petadopt.controller.MenuPrincipalController">
    <children>

        <MenuBar style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 0 0 1 0;">
            <menus>
                <Menu text="Menú">
                    <items>
                        <MenuItem onAction="#abrirAnimales" text="Animales" />
                        <MenuItem onAction="#abrirVoluntarios" text="Voluntarios" />
                        <MenuItem onAction="#abrirTareas" text="Tareas" />
                        <MenuItem onAction="#abrirAdoptantes" text="Adoptantes" />
                        <MenuItem onAction="#abrirHistorial" text="Historial Tareas" />
                    </items>
                </Menu>
                <Menu text="Archivo">
                    <items>
                        <MenuItem onAction="#abrirMenuPrincipal" text="Volver al Inicio" />
                        <SeparatorMenuItem />
                        <MenuItem onAction="#btnSalir" text="Cerrar Ventana" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>

        <VBox alignment="CENTER" spacing="35.0" VBox.vgrow="ALWAYS">
            <children>

                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <ImageView fitHeight="153.0" fitWidth="286.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@img/PetAdopt.png" />
                            </image>
                        </ImageView>
                        <Label textFill="#6c757d">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <HBox alignment="CENTER" spacing="20.0">
                    <children>

                        <VBox alignment="CENTER" prefHeight="100.0" prefWidth="180.0" style="-fx-background-color: #e8f5e9; -fx-border-color: #81c784; -fx-border-radius: 6; -fx-background-radius: 6;">
                            <children>
                                <Label text="ANIMALES" textFill="#2e7d32">
                                    <font><Font name="System Bold" size="11.0" /></font>
                                </Label>
                                <Label fx:id="lblTotalAnimales" text="0" textFill="#1b5e20">
                                    <font><Font name="System Bold" size="28.0" /></font>
                                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                                </Label>
                                <Label text="Refugiados actuales" textFill="#4caf50">
                                    <font><Font size="11.0" /></font>
                                </Label>
                            </children>
                            <padding><Insets bottom="12.0" left="15.0" right="15.0" top="12.0" /></padding>
                        </VBox>

                        <VBox alignment="CENTER" prefHeight="100.0" prefWidth="180.0" style="-fx-background-color: #e3f2fd; -fx-border-color: #64b5f6; -fx-border-radius: 6; -fx-background-radius: 6;">
                            <children>
                                <Label text="VOLUNTARIOS" textFill="#0d47a1">
                                    <font><Font name="System Bold" size="11.0" /></font>
                                </Label>
                                <Label fx:id="lblTotalVoluntarios" text="0" textFill="#0d47a1">
                                    <font><Font name="System Bold" size="28.0" /></font>
                                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                                </Label>
                                <Label text="Personal activo" textFill="#2196f3">
                                    <font><Font size="11.0" /></font>
                                </Label>
                            </children>
                            <padding><Insets bottom="12.0" left="15.0" right="15.0" top="12.0" /></padding>
                        </VBox>

                        <VBox alignment="CENTER" prefHeight="100.0" prefWidth="180.0" style="-fx-background-color: #fff3e0; -fx-border-color: #ffb74d; -fx-border-radius: 6; -fx-background-radius: 6;">
                            <children>
                                <Label text="TAREAS PENDIENTES" textFill="#e65100">
                                    <font><Font name="System Bold" size="11.0" /></font>
                                </Label>
                                <Label fx:id="lblTareasPendientes" text="0" textFill="#e65100">
                                    <font><Font name="System Bold" size="28.0" /></font>
                                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                                </Label>
                                <Label text="Por realizar hoy" textFill="#ff9800">
                                    <font><Font size="11.0" /></font>
                                </Label>
                            </children>
                            <padding><Insets bottom="12.0" left="15.0" right="15.0" top="12.0" /></padding>
                        </VBox>

                    </children>
                </HBox>

                <VBox alignment="CENTER" spacing="12.0">
                    <children>
                        <Label text="Accesos Directos de Gestión" textFill="#495057">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <HBox alignment="CENTER" spacing="15.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#abrirAnimales" prefHeight="45.0" prefWidth="140.0" style="-fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text=" Animales" textFill="#495057">
                                    <font><Font name="System Bold" size="13.0" /></font>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#abrirVoluntarios" prefHeight="45.0" prefWidth="140.0" style="-fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Voluntarios" textFill="#495057">
                                    <font><Font name="System Bold" size="13.0" /></font>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#abrirTareas" prefHeight="45.0" prefWidth="140.0" style="-fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Tareas" textFill="#495057">
                                    <font><Font name="System Bold" size="13.0" /></font>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#abrirAdoptantes" prefHeight="45.0" prefWidth="140.0" style="-fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Adoptantes" textFill="#495057">
                                    <font><Font name="System Bold" size="13.0" /></font>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </VBox>

            </children>
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="20.0" />
            </padding>
        </VBox>
    </children>
</VBox>

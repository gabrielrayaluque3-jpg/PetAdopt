<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox minHeight="500.0" minWidth="750.0" spacing="15.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="es.iesfranciscodelosrios.petadopt.controller.HistorialTareasController">
    <children>

        <MenuBar style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 0 0 1 0;">
            <menus>
                <Menu text="Menú">
                    <items>
                        <MenuItem onAction="#abrirAnimales" text="Animales" />
                        <MenuItem onAction="#abrirVoluntarios" text="Voluntarios" />
                        <MenuItem onAction="#abrirTareas" text="Tareas" />
                        <MenuItem onAction="#abrirAdoptantes" text="Adoptantes" />
                        <MenuItem onAction="#abrirHistorial" text="Historial Tareas" />
                    </items>
                </Menu>
                <Menu text="Archivo">
                    <items>
                        <MenuItem onAction="#abrirMenuPrincipal" text="Volver al Inicio" />
                        <SeparatorMenuItem />
                        <MenuItem onAction="#btnSalir" text="Cerrar Ventana" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>

        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 0 0 1 0;">
            <children>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Historial de Asignación de Tareas" textFill="#212529">
                            <font>
                                <Font name="System Bold" size="22.0" />
                            </font>
                        </Label>
                        <Label text="Supervisa el estado de las actividades y las asignaciones de los voluntarios." textFill="#6c757d">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                    <children>
                        <TextField fx:id="txtBuscador" onKeyTyped="#filtrarHistorial" prefHeight="32.0" prefWidth="280.0" promptText="🔍 Buscar por voluntario..." style="-fx-background-radius: 4; -fx-border-color: #ced4da; -fx-border-radius: 4;" />
                        <ComboBox fx:id="cmbFiltroEstado" onAction="#filtrarPorEstado" prefHeight="32.0" prefWidth="140.0" promptText="Todos los estados" style="-fx-background-radius: 4; -fx-border-color: #ced4da; -fx-border-radius: 4; -fx-background-color: #ffffff;" />
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
            </padding>
        </HBox>

        <TableView fx:id="tblHistorial" style="-fx-background-radius: 4; -fx-border-color: #dee2e6;" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colIdTarea" prefWidth="100.0" text="ID Tarea" />
                <TableColumn fx:id="colVoluntario" prefWidth="200.0" text="Nombre Voluntario" />
                <TableColumn fx:id="colFecha" prefWidth="150.0" text="Fecha Asignada" />
                <TableColumn fx:id="colCompletada" prefWidth="120.0" text="Estado Actual" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <VBox.margin>
                <Insets left="25.0" right="25.0" top="5.0" />
            </VBox.margin>
        </TableView>

        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <Button onAction="#btnAsignarTarea" prefHeight="38.0" prefWidth="180.0" style="-fx-background-color: #e3f2fd; -fx-border-color: #2196f3; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Asignar Nueva Tarea" textFill="#0d47a1">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
                <Button onAction="#eliminarRegistro" prefHeight="38.0" prefWidth="180.0" style="-fx-background-color: #ffebee; -fx-border-color: #f44336; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Eliminar Registro" textFill="#c62828">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
            <VBox.margin>
                <Insets bottom="20.0" top="10.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="650.0" prefWidth="1000.0" spacing="15.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="es.iesfranciscodelosrios.petadopt.controller.AdoptantesMainController">
    <children>

        <MenuBar style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 0 0 1 0;">
            <menus>
                <Menu text="Menú">
                    <items>
                        <MenuItem onAction="#abrirMenuPrincipal" text="Inicio" />
                        <MenuItem onAction="#abrirAnimales" text="Animales" />
                        <MenuItem onAction="#abrirVoluntarios" text="Voluntarios" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>

        <VBox spacing="5.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 0 0 1 0;">
            <children>
                <Label text="Gestión de Adoptantes" textFill="#212529">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
                <Label text="Administra los perfiles de los adoptantes y consulta sus respectivas mascotas vinculadas." textFill="#6c757d">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Label>
            </children>
            <padding>
                <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
            </padding>
        </VBox>

        <TableView fx:id="tvAdoptantes" style="-fx-background-radius: 4; -fx-border-color: #dee2e6;" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                <TableColumn fx:id="colDni" prefWidth="120.0" text="DNI" />
                <TableColumn fx:id="colNombre" prefWidth="220.0" text="Nombre Completo" />
                <TableColumn fx:id="colTelefono" prefWidth="120.0" text="Teléfono" />
                <TableColumn fx:id="colEmail" prefWidth="240.0" text="Email" />
                <TableColumn fx:id="colNumAnimales" prefWidth="160.0" text="Mascotas Adoptadas" />
            </columns>
            <VBox.margin>
                <Insets left="25.0" right="25.0" top="5.0" />
            </VBox.margin>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <Button onAction="#btnAddAdoptante" prefHeight="38.0" prefWidth="160.0" style="-fx-background-color: #e8f5e9; -fx-border-color: #4caf50; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Añadir Adoptante" textFill="#2e7d32">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
                <Button onAction="#btnEditar" prefHeight="38.0" prefWidth="160.0" style="-fx-background-color: #e3f2fd; -fx-border-color: #2196f3; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Editar Adoptante" textFill="#0d47a1">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
                <Button onAction="#btnEliminar" prefHeight="38.0" prefWidth="160.0" style="-fx-background-color: #ffebee; -fx-border-color: #f44336; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Eliminar Adoptante" textFill="#c62828">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
                <Button onAction="#btnDetallatesAdopcion" prefHeight="38.0" prefWidth="210.0" style="-fx-background-color: #fff3e0; -fx-border-color: #ff9800; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Ver Mascotas Adoptadas" textFill="#e65100">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
            <VBox.margin>
                <Insets bottom="20.0" top="10.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>
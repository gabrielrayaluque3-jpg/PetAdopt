<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefWidth="500.0" prefHeight="550.0" style="-fx-background-color: #ffffff;" spacing="0.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="es.iesfranciscodelosrios.petadopt.controller.AddTareaController">
    <children>

        <MenuBar style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 0 0 1 0;">
            <menus>
                <Menu text="Menú">
                    <items>
                        <MenuItem onAction="#btnAnimales" text="Animales" />
                        <MenuItem onAction="#btnVoluntarios" text="Voluntarios" />
                        <MenuItem onAction="#btnTareas" text="Tareas" />
                        <MenuItem onAction="#btnAdoptantes" text="Adoptantes" />
                        <MenuItem onAction="#btnHistorial" text="Historial Tareas" />
                    </items>
                </Menu>
                <Menu text="Archivo">
                    <items>
                        <MenuItem onAction="#btnMenuPrincipal" text="Volver al Inicio" />
                        <SeparatorMenuItem />
                        <MenuItem onAction="#btnSalir" text="Cerrar Ventana" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>

        <VBox spacing="5.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 0 0 1 0;">
            <children>
                <Label text="Nueva Tarea para el Refugio" textFill="#212529">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                <Label text="Asigna un título, descripción y nivel de prioridad a la nueva actividad." textFill="#6c757d">
                    <font>
                        <Font size="12.0" />
                    </font>
                </Label>
            </children>
            <padding>
                <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
            </padding>
        </VBox>

        <GridPane hgap="15.0" vgap="18.0" VBox.vgrow="ALWAYS">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" minWidth="90.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="35.0" vgrow="NEVER" />
                <RowConstraints minHeight="100.0" vgrow="ALWAYS" />
                <RowConstraints minHeight="35.0" vgrow="NEVER" />
            </rowConstraints>
            <children>
                <Label text="Nombre:" textFill="#495057" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>
                <TextField fx:id="txtNombre" prefHeight="32.0" promptText="Ej: Alimentar cachorros, Limpieza de jaulas..." style="-fx-background-radius: 4; -fx-border-color: #ced4da; -fx-border-radius: 4;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Descripción:" textFill="#495057" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.valignment="TOP">
                    <font><Font name="System Bold" size="13.0" /></font>
                    <GridPane.margin><Insets top="5.0" /></GridPane.margin>
                </Label>
                <TextArea fx:id="txtDescripcion" promptText="Detalla los pasos o consideraciones de la tarea..." wrapText="true" style="-fx-background-radius: 4; -fx-border-color: #ced4da; -fx-border-radius: 4;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Prioridad:" textFill="#495057" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>
                <ComboBox fx:id="cmbPrioridad" maxWidth="1.7976931348623157E308" prefHeight="32.0" promptText="Seleccione la prioridad..." style="-fx-background-radius: 4; -fx-border-color: #ced4da; -fx-border-radius: 4; -fx-background-color: #ffffff;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            </children>
            <padding>
                <Insets bottom="20.0" left="25.0" right="30.0" top="20.0" />
            </padding>
        </GridPane>

        <HBox alignment="CENTER_RIGHT" spacing="12.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 1 0 0 0;">
            <children>
                <Button onAction="#cancelar" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Cancelar" textFill="#495057">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
                <Button fx:id="btnGuardar" onAction="#guardarDatos" prefHeight="35.0" prefWidth="110.0" style="-fx-background-color: #2196f3; -fx-background-radius: 4; -fx-cursor: hand;" text="Guardar" textFill="WHITE">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
            <padding>
                <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
            </padding>
        </HBox>
    </children>
</VBox>
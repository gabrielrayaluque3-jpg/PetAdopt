<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox minHeight="550.0" minWidth="750.0" prefHeight="650.0" prefWidth="950.0" spacing="15.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="es.iesfranciscodelosrios.petadopt.controller.VoluntariosMainController">
    <children>

        <MenuBar style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 0 0 1 0;">
            <menus>
                <Menu text="Menú">
                    <items>
                        <MenuItem onAction="#abrirAnimales" text="Animales" />
                        <MenuItem onAction="#abrirVoluntarios" text="Voluntarios" />
                        <MenuItem onAction="#abrirTareas" text="Tareas" />
                        <MenuItem onAction="#abrirAdoptantes" text="Adoptantes" />
                        <MenuItem onAction="#abrirHistorial" text="Historial Tareas" />
                    </items>
                </Menu>
                <Menu text="Archivo">
                    <items>
                        <MenuItem onAction="#abrirMenuPrincipal" text="Volver al Inicio" />
                        <SeparatorMenuItem />
                        <MenuItem onAction="#onSalirClick" text="Cerrar Ventana" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>

        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 0 0 1 0;">
            <children>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Gestión de Voluntarios" textFill="#212529">
                            <font>
                                <Font name="System Bold" size="22.0" />
                            </font>
                        </Label>
                        <Label text="Administra el personal del refugio, sus datos de contacto y sus especialidades." textFill="#6c757d">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <TextField fx:id="txtBuscador" onKeyTyped="#filtrarLista" prefHeight="32.0" prefWidth="250.0" promptText="🔍 Buscar voluntario..." style="-fx-background-radius: 4 0 0 4; -fx-border-color: #ced4da; -fx-border-radius: 4 0 0 4;" />
                        <MenuButton mnemonicParsing="false" prefHeight="32.0" style="-fx-background-radius: 0 4 4 0; -fx-border-color: #ced4da; -fx-border-radius: 0 4 4 0; -fx-background-color: #ffffff; -fx-cursor: hand;" text="Filtro">
                            <items>
                                <MenuItem onAction="#filtroAll" text="Todos" />
                                <MenuItem onAction="#filtroId" text="ID" />
                                <MenuItem onAction="#filtroNombre" text="Nombre" />
                                <MenuItem onAction="#filtroEspecialidad" text="Especialidad" />
                            </items>
                            <font><Font size="12.0" /></font>
                            <HBox.margin><Insets left="-11.0" /></HBox.margin> </MenuButton>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
            </padding>
        </HBox>

        <TableView fx:id="tblVoluntarios" style="-fx-background-radius: 4; -fx-border-color: #dee2e6;" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" maxWidth="80.0" minWidth="50.0" prefWidth="60.0" text="ID" />
                <TableColumn fx:id="colNombre" prefWidth="220.0" text="Nombre" />
                <TableColumn fx:id="colDni" maxWidth="150.0" minWidth="100.0" prefWidth="120.0" text="DNI" />
                <TableColumn fx:id="colEspecialidad" prefWidth="250.0" text="Especialidad" />
            </columns>
            <VBox.margin>
                <Insets left="25.0" right="25.0" top="5.0" />
            </VBox.margin>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <Button fx:id="btnAñadir" mnemonicParsing="false" onAction="#addVoluntario" prefHeight="38.0" prefWidth="140.0" style="-fx-background-color: #e8f5e9; -fx-border-color: #4caf50; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Añadir Voluntario" textFill="#2e7d32">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
                <Button mnemonicParsing="false" onAction="#UpdateVoluntario" prefHeight="38.0" prefWidth="140.0" style="-fx-background-color: #e3f2fd; -fx-border-color: #2196f3; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Editar Voluntario" textFill="#0d47a1">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
                <Button fx:id="btnEliminar" mnemonicParsing="false" onAction="#eliminarVoluntario" prefHeight="38.0" prefWidth="140.0" style="-fx-background-color: #ffebee; -fx-border-color: #f44336; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Eliminar Registro" textFill="#c62828">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
            <VBox.margin>
                <Insets bottom="20.0" top="10.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>

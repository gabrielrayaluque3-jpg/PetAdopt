<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox minHeight="550.0" minWidth="750.0" prefHeight="650.0" prefWidth="950.0" spacing="15.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="es.iesfranciscodelosrios.petadopt.controller.TareasMainController">
    <children>

        <MenuBar style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 0 0 1 0;">
            <menus>
                <Menu text="Menú">
                    <items>
                        <MenuItem onAction="#abrirAnimales" text="Animales" />
                        <MenuItem onAction="#abrirVoluntarios" text="Voluntarios" />
                        <MenuItem onAction="#abrirTareas" text="Tareas" />
                        <MenuItem onAction="#abrirAdoptantes" text="Adoptantes" />
                        <MenuItem onAction="#abrirHistorial" text="Historial Tareas" />
                    </items>
                </Menu>
                <Menu text="Archivo">
                    <items>
                        <MenuItem onAction="#abrirMenuPrincipal" text="Volver al Inicio" />
                        <SeparatorMenuItem />
                        <MenuItem onAction="#btnSalir" text="Cerrar Ventana" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>

        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-width: 0 0 1 0;">
            <children>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Gestión de Tareas" textFill="#212529">
                            <font>
                                <Font name="System Bold" size="22.0" />
                            </font>
                        </Label>
                        <Label text="Organiza las actividades diarias del refugio y define los niveles de urgencia." textFill="#6c757d">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <TextField fx:id="txtBuscador" onKeyTyped="#filtrarTareas" prefHeight="32.0" prefWidth="250.0" promptText="🔍 Buscar actividad..." style="-fx-background-radius: 4 0 0 4; -fx-border-color: #ced4da; -fx-border-radius: 4 0 0 4;" />
                        <MenuButton fx:id="menuFiltro" mnemonicParsing="false" prefHeight="32.0" text="Filtrar por" style="-fx-background-radius: 0 4 4 0; -fx-border-color: #ced4da; -fx-border-radius: 0 4 4 0; -fx-background-color: #ffffff; -fx-cursor: hand;">
                            <items>
                                <MenuItem mnemonicParsing="false" onAction="#filtroNombre" text="Nombre" />
                                <MenuItem mnemonicParsing="false" onAction="#filtroDescripcion" text="Descripción" />
                                <MenuItem mnemonicParsing="false" onAction="#filtroPrioridad" text="Prioridad" />
                            </items>
                            <font><Font size="12.0" /></font>
                            <HBox.margin><Insets left="-11.0" /></HBox.margin> </MenuButton>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
            </padding>
        </HBox>

        <TableView fx:id="tblTareas" style="-fx-background-radius: 4; -fx-border-color: #dee2e6;" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" maxWidth="60.0" minWidth="40.0" prefWidth="50.0" text="ID" />
                <TableColumn fx:id="colNombre" prefWidth="180.0" text="Nombre" />
                <TableColumn fx:id="colDescripcion" prefWidth="300.0" text="Descripción" />
                <TableColumn fx:id="colPrioridad" maxWidth="120.0" minWidth="80.0" prefWidth="100.0" text="Prioridad" />
            </columns>
            <VBox.margin>
                <Insets left="25.0" right="25.0" top="5.0" />
            </VBox.margin>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <Button mnemonicParsing="false" onAction="#btnAddTarea" prefHeight="38.0" prefWidth="150.0" style="-fx-background-color: #e8f5e9; -fx-border-color: #4caf50; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Añadir Tareas" textFill="#2e7d32">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
                <Button fx:id="btnEditar" mnemonicParsing="false" onAction="#btnEditar" prefHeight="38.0" prefWidth="150.0" style="-fx-background-color: #e3f2fd; -fx-border-color: #2196f3; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Editar Tarea" textFill="#0d47a1">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
                <Button fx:id="btnEliminar" mnemonicParsing="false" onAction="#btnEliminar" prefHeight="38.0" prefWidth="150.0" style="-fx-background-color: #ffebee; -fx-border-color: #f44336; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Eliminar Tarea" textFill="#c62828">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
                <Button mnemonicParsing="false" onAction="#btnHistorial" prefHeight="38.0" prefWidth="160.0" style="-fx-background-color: #fff3e0; -fx-border-color: #ff9800; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="Ir al Historial" textFill="#e65100">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
            <VBox.margin>
                <Insets bottom="20.0" top="10.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>